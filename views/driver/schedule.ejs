<!DOCTYPE html><html><head><title>Driver Schedule - eRide</title><meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=yes"><style>body { font-family: 'Noto Sans', sans-serif; margin: 0; padding: 15px; background: #e9ecef; font-size: 18px; } .card { background: white; padding: 20px; margin-bottom: 15px; border-radius: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); } h2 { margin: 0 0 15px 0; color: #333; } .badge { background: #28a745; color: white; padding: 4px 10px; border-radius: 20px; font-size: 14px; } .booking-item { border-bottom: 1px solid #eee; padding: 15px 0; } .booking-item:last-child { border-bottom: none; } .time { font-size: 22px; font-weight: bold; color: #007bff; } .address { font-size: 18px; margin: 8px 0; color: #444; } .phone-btn { background: #25D366; color: white; padding: 12px 20px; text-decoration: none; border-radius: 30px; display: inline-block; margin-top: 10px; font-weight: bold; text-align: center; width: 100%; box-sizing: border-box; } .complete-btn { background: #007bff; color: white; border: none; padding: 12px; width: 100%; border-radius: 30px; font-size: 18px; margin-top: 10px; } .empty-state { text-align: center; padding: 40px; color: #666; } .driver-header { background: #007bff; color: white; padding: 15px; margin: -15px -15px 20px -15px; border-radius: 0 0 20px 20px; }</style></head><body><div class="driver-header"><h2>👋 Namaste, <%= driver.name %></h2><p>Vehicle: <%= driver.vehicleNumber %> | Cash Balance: ₹<%= driver.walletBalance || 0 %></p></div><h3>📅 Aaj Ki Savaariyaan</h3><% if (todayBookings.length > 0) { %><% todayBookings.forEach(booking => { %><div class="card"><span class="badge">Today</span><div class="time"><%= new Date(booking.pickupDate).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></div><div class="address"><strong>📍 Pickup:</strong> <%= booking.pickupLocation.address %></div><div class="address"><strong>🏁 Drop:</strong> <%= booking.dropLocation.address %></div><div><strong>👤 Passenger:</strong> <%= booking.guestName %> (<%= booking.guestPhone %>)</div><a href="tel:<%= booking.guestPhone %>" class="phone-btn">📞 Call Passenger</a><form method="POST" action="/driver/complete/<%= booking._id %>" style="margin-top: 10px;"><button type="submit" class="complete-btn">✅ Ride Completed (Cash Collected)</button></form></div><% }) %><% } else { %><div class="card empty-state">Aaj koi ride nahi hai. Kal ki schedule neeche dekhein.</div><% } %><h3>📆 Kal Ki Booking (<%= tomorrowBookings.length %>)</h3><% if (tomorrowBookings.length > 0) { %><% tomorrowBookings.forEach(booking => { %><div class="card"><div class="time"><%= new Date(booking.pickupDate).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></div><div class="address"><strong>📍 Pickup:</strong> <%= booking.pickupLocation.address %></div><div class="address"><strong>🏁 Drop:</strong> <%= booking.dropLocation.address %></div><div><strong>👤 Passenger:</strong> <%= booking.guestName %></div><div><strong>📞 Contact:</strong> <%= booking.guestPhone %></div><div style="margin-top: 10px;"><em><%= booking.specialNote || 'No special note' %></em></div><a href="tel:<%= booking.guestPhone %>" class="phone-btn" style="background: #6c757d;">📞 Call Now (Confirm)</a></div><% }) %><% } else { %><div class="card empty-state">Kal ke liye abhi koi booking nahi hai. Aaram karein.</div><% } %><p style="text-align: center; margin-top: 30px; color: #888;">eRide Driver App v1.0</p></body></html>
